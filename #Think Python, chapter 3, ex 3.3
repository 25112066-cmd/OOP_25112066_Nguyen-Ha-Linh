#2. Write a function that draws a similar grid with four rows and four columns. (fill with number 4)
def grid(a):
    for i in range (a):
        print (('+ '+'- '*4)*a+'+ ')
        for i in range(4):
            print (('| '+' '*8)*a+'| ')
    print (('+ '+'- '*4)*a+'+ ')
a=int(input('2.Enter a:'))
grid(a)
