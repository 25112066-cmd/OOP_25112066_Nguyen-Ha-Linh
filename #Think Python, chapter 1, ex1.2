#1. How many seconds are there in 42 minutes 42 seconds?
minutes = 42
seconds = 42
totalseconds = minutes*60+seconds
print("Total seconds:",totalseconds)

#2. How many miles are there in 10 kilometers? Hint: there are 1.61 kilometers in a mile.
mile = 1.61
km = 10
totalmiles = km/mile
print("Total miles 10:",totalmiles)

#3. If you run a 10 kilometers in 42 minutes 42 seconds, what is your average pace (time per mile in minutes and seconds)? What is your average speed in miles per hour?
pace = totalseconds / totalmiles
h = totalseconds / 3600
print("Average pace:", pace)
speed = totalmiles / h
print("Average speed:", speed, "mph")
